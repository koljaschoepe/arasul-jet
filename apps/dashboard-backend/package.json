{
  "name": "arasul-dashboard-backend",
  "version": "1.0.0",
  "description": "Arasul Platform Dashboard Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --verbose --maxWorkers=2",
    "test:ci": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "lint:report": "eslint src/ --ext .js --format json --output-file eslint-report.json"
  },
  "dependencies": {
    "@arasul/shared-schemas": "file:../../packages/shared-schemas",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dockerode": "^5.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.3.0",
    "js-yaml": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^7.1.3",
    "multer": "^2.0.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.0",
    "tar": "^7.4.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/**/*.test.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^pdfkit$": "<rootDir>/__mocks__/pdfkit.js",
      "^helmet$": "<rootDir>/__mocks__/helmet.js"
    },
    "coverageThreshold": {
      "global": {
        "branches": 25,
        "functions": 35,
        "lines": 38,
        "statements": 38
      }
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
