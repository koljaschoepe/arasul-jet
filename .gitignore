# Arasul Platform - Git Ignore

# Environment files with secrets
.env
.env.bak
.env.local
.env.*.local
.env.jetson

# Data directories
/data/
/logs/
/cache/
/updates/

# System-generated files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/
coverage/
*.log

# Exception: shared package build outputs are checked in so Dockerfiles
# and downstream workspaces can consume without a build-stage bootstrap.
!packages/*/dist/

# Node modules
node_modules/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Docker volumes (local testing)
postgres_data/
minio_data/
n8n_data/

# Temporary files
*.tmp
*.temp

# Secrets
*.pem
*.key
admin.hash
config/secrets/
!config/secrets/.example/
config/.traefik-credentials
config/certs/
config/ssh/

# Device-specific configuration (not versioned)
config/device/
config/profiles/
config/dev/

# Environment backups
.env.backup.*
*.backup
*.backup.*
*.bak

# Local tool configuration
.mcp.json
.claude/plans/
config/base/
