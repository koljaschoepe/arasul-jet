# =============================================================================
# Arasul Platform - Environment Configuration Template
# =============================================================================
#
# Copy this file to .env and fill in the required values:
#   cp .env.template .env
#
# Or run the auto-configuration script (generates secure random credentials):
#   ./scripts/setup/preconfigure.sh
#
# NOTE: The preconfigure.sh script checks for .env.example as a template
#       (see ENV_TEMPLATE variable in preconfigure.sh line 207).
#       You may also symlink: ln -s .env.template .env.example
#
# Variables marked (required) MUST be set before starting.
# Variables marked (auto) are auto-detected by detect-jetson.sh.
# Variables with defaults can be omitted (the shown value is the default).
#
# =============================================================================


# =============================================================================
# 1. SYSTEM
# =============================================================================

# System identification
SYSTEM_VERSION=1.0.0
BUILD_HASH=dev-build

# Timezone (used by n8n and backup-service)
TZ=Europe/Berlin

# Build versions for Docker images (build args in compose files)
NODE_VERSION=20.19
PYTHON_VERSION=3.11.12

# Project directory (absolute path on the host machine)
# Used by dashboard-backend for Docker Compose operations
COMPOSE_PROJECT_DIR=.

# Global log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Self-Healing Agent log level (separate from global LOG_LEVEL)
SELF_HEALING_LOG_LEVEL=INFO


# =============================================================================
# 2. AUTHENTICATION (required)
# =============================================================================

# Dashboard admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT token signing key (required, 32+ characters)
# Generate with: openssl rand -base64 64 | tr -dc 'a-zA-Z0-9' | head -c 64
JWT_SECRET=your-jwt-secret-here-must-be-at-least-32-characters

# JWT token expiration time
# IMPORTANT: The backend reads process.env.JWT_EXPIRY (see
# apps/dashboard-backend/src/utils/jwt.js:20). The preconfigure.sh script
# historically generated JWT_EXPIRES_IN, which is IGNORED by the backend.
# Always use JWT_EXPIRY here.
JWT_EXPIRY=24h


# =============================================================================
# 3. POSTGRESQL DATABASE
# =============================================================================

# Connection settings
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
POSTGRES_USER=arasul
POSTGRES_PASSWORD=changeme
POSTGRES_DB=arasul_db

# Server tuning
POSTGRES_MAX_CONNECTIONS=100

# --- Datentabellen (Dynamic User Database) ---
# Separate database for user-created tables (ExcelEditor / Datentabellen feature)
ARASUL_DATA_DB_HOST=postgres-db
ARASUL_DATA_DB_PORT=5432
ARASUL_DATA_DB_NAME=arasul_data_db
ARASUL_DATA_DB_USER=arasul_data
# Defaults to POSTGRES_PASSWORD if not set
ARASUL_DATA_DB_PASSWORD=


# =============================================================================
# 4. MINIO (S3-Compatible Object Storage)
# =============================================================================

MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=arasul
MINIO_ROOT_PASSWORD=changeme
# Enable MinIO web console (port 9001)
MINIO_BROWSER=true


# =============================================================================
# 5. DASHBOARD BACKEND
# =============================================================================

# Backend API listen port (internal, behind reverse proxy)
DASHBOARD_BACKEND_PORT=3001


# =============================================================================
# 6. LLM SERVICE (Ollama)
# =============================================================================

# Service connection (Docker service name and port)
LLM_SERVICE_HOST=llm-service
LLM_SERVICE_PORT=11434

# Default LLM model (auto-detected by detect-jetson.sh based on available RAM)
LLM_MODEL=qwen3:14b-q8

# Seconds to keep model loaded in GPU memory after last request
LLM_KEEP_ALIVE_SECONDS=300

# Max seconds to wait for Ollama to start
OLLAMA_STARTUP_TIMEOUT=120

# Knowledge Graph refinement model (used by document-indexer for KG extraction)
KG_REFINE_MODEL=mistral:7b


# =============================================================================
# 7. EMBEDDING SERVICE
# =============================================================================

# Service connection
EMBEDDING_SERVICE_HOST=embedding-service
EMBEDDING_SERVICE_PORT=11435

# HuggingFace embedding model name
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Output vector dimensions (must match the chosen model)
EMBEDDING_VECTOR_SIZE=1024

# Maximum input token length
EMBEDDING_MAX_INPUT_TOKENS=8192


# =============================================================================
# 8. QDRANT (Vector Database)
# =============================================================================

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents


# =============================================================================
# 9. DOCUMENT INDEXER
# =============================================================================

# Scan interval for new/changed documents (seconds)
DOCUMENT_INDEXER_INTERVAL=30

# Chunking configuration (characters)
DOCUMENT_INDEXER_CHUNK_SIZE=500
DOCUMENT_INDEXER_CHUNK_OVERLAP=50

# Hierarchical (parent-child) chunking (tokens)
DOCUMENT_INDEXER_PARENT_CHUNK_SIZE=2000
DOCUMENT_INDEXER_CHILD_CHUNK_SIZE=400
DOCUMENT_INDEXER_CHILD_CHUNK_OVERLAP=50

# MinIO bucket for document storage
DOCUMENT_INDEXER_MINIO_BUCKET=documents

# Internal API port
# Document indexer service hostname
DOCUMENT_INDEXER_HOST=document-indexer

DOCUMENT_INDEXER_API_PORT=9102

# AI-powered indexing features
DOCUMENT_INDEXER_ENABLE_AI=true
DOCUMENT_INDEXER_ENABLE_SIMILARITY=true
DOCUMENT_INDEXER_SIMILARITY_THRESHOLD=0.8

# Maximum document file size (MB)
DOCUMENT_MAX_SIZE_MB=100


# =============================================================================
# 10. N8N (Workflow Engine)
# =============================================================================

# Service connection
N8N_HOST=n8n
N8N_PORT=5678

# Protocol and cookie settings
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false

# Public URLs (set when using Cloudflare Tunnel for OAuth callbacks / webhooks)
N8N_EXTERNAL_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678

# Encryption key for stored credentials (required, 32+ characters)
# Generate with: openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32
N8N_ENCRYPTION_KEY=your-n8n-encryption-key-at-least-32-characters

# Basic auth credentials (used by preconfigure.sh for Traefik middleware)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme


# =============================================================================
# 11. CLOUDFLARE TUNNEL (Optional)
# =============================================================================
# Activate with: docker compose --profile tunnel up -d
# Leave empty to disable the tunnel container.

CLOUDFLARE_TUNNEL_TOKEN=


# =============================================================================
# 12. MONITORING - Metrics Collector
# =============================================================================

# Live metrics WebSocket push interval (seconds)
METRICS_INTERVAL_LIVE=5

# How often to persist metrics to PostgreSQL (seconds)
METRICS_INTERVAL_PERSIST=30


# =============================================================================
# 13. MONITORING - Self-Healing Agent
# =============================================================================

# Health check interval (seconds)
SELF_HEALING_INTERVAL=10

# Enable or disable automated healing actions
SELF_HEALING_ENABLED=true

# Heartbeat HTTP port for liveness checks
SELF_HEALING_HEARTBEAT_PORT=9200

# --- Disk Thresholds (progressive response) ---
DISK_WARNING_PERCENT=80
DISK_CLEANUP_PERCENT=90
DISK_CRITICAL_PERCENT=95
DISK_REBOOT_PERCENT=97


# =============================================================================
# 14. BACKUP SERVICE
# =============================================================================

# Cron schedule for automated backups (default: 2:00 AM daily)
BACKUP_SCHEDULE=0 2 * * *

# Number of days to retain daily backups
BACKUP_RETENTION_DAYS=30


# =============================================================================
# 15. GPU / CUDA
# =============================================================================

# CUDA compute capability for PyTorch compilation
# 8.7 = Orin, 7.2 = Xavier, 6.2 = TX2, 5.3 = Nano
# Auto-detected by detect-jetson.sh
TORCH_CUDA_ARCH_LIST=8.7


# =============================================================================
# 16. RESOURCE LIMITS - Memory (auto)
# =============================================================================
# Auto-generated by detect-jetson.sh based on the detected device profile.
# Values use Docker memory notation (e.g., 512M, 2G, 48G).
#
# The defaults below are for AGX Orin 64GB. Run detect-jetson.sh to get
# optimal values for your device, or see compose file defaults (:-notation).

RAM_LIMIT_POSTGRES=2G
RAM_LIMIT_LLM=48G
RAM_LIMIT_EMBEDDING=8G
RAM_LIMIT_BACKEND=1G
RAM_LIMIT_FRONTEND=256M
RAM_LIMIT_N8N=2G
RAM_LIMIT_QDRANT=6G
RAM_LIMIT_MINIO=4G
RAM_LIMIT_METRICS=512M
RAM_LIMIT_SELF_HEALING=512M
RAM_LIMIT_DOCUMENT_INDEXER=2G
RAM_LIMIT_REVERSE_PROXY=512M
RAM_LIMIT_BACKUP=256M
RAM_LIMIT_CLOUDFLARED=128M
RAM_LIMIT_LOKI=512M
RAM_LIMIT_PROMTAIL=256M


# =============================================================================
# 17. RESOURCE LIMITS - CPU (auto)
# =============================================================================
# CPU core limits for compute-intensive services.
# Auto-generated by detect-jetson.sh based on the detected device profile.

CPU_LIMIT_LLM=10
CPU_LIMIT_EMBEDDING=4
CPU_LIMIT_DASHBOARD=4
