# Remove plaintext ADMIN_PASSWORD from .env after bootstrap
# The bcrypt hash is stored in config/secrets/admin.hash and the DB.
# The plaintext password is no longer needed.
redact_plaintext_password() {
    if [ ! -f .env ]; then
        return 0
    fi

    local current_val
    current_val=$(grep "^ADMIN_PASSWORD=" .env | cut -d'=' -f2)

    # Skip if already redacted or empty
    if [ -z "$current_val" ] || [ "$current_val" = "REDACTED_AFTER_BOOTSTRAP" ]; then
        return 0
    fi

    sed -i 's/^ADMIN_PASSWORD=.*/ADMIN_PASSWORD=REDACTED_AFTER_BOOTSTRAP/' .env

    if grep -q "^ADMIN_PASSWORD=REDACTED_AFTER_BOOTSTRAP" .env; then
        log_success "Klartext-Passwort aus .env entfernt (Sicherheit)"
    else
        log_warning "Konnte Klartext-Passwort nicht aus .env entfernen"
    fi
}

# Production security hardening (SSH + Firewall)
# Non-critical: failures warn but don't block bootstrap
harden_production_security() {
    local node_env
    node_env=$(grep "^NODE_ENV=" .env 2>/dev/null | cut -d'=' -f2)

    # SSH Hardening (production only, opt-out via ENABLE_SSH_HARDENING=false)
    if [ "${ENABLE_SSH_HARDENING:-true}" = "true" ] && [ "${node_env}" = "production" ]; then
        log_info "SSH-Hardening wird angewendet..."
        if [ -f "scripts/security/harden-ssh.sh" ]; then
            bash scripts/security/harden-ssh.sh --port "${SSH_PORT:-2222}" --non-interactive 2>/dev/null || {
                log_warning "SSH-Hardening fehlgeschlagen (nicht kritisch)"
            }
        else
            log_warning "SSH-Hardening-Script nicht gefunden: scripts/security/harden-ssh.sh"
        fi
    elif [ "${ENABLE_SSH_HARDENING:-true}" != "true" ]; then
        log_info "SSH-Hardening uebersprungen (ENABLE_SSH_HARDENING=false)"
    else
        log_info "SSH-Hardening uebersprungen (NODE_ENV != production)"
    fi

    # Firewall Setup (production only, opt-out via ENABLE_FIREWALL=false)
    if [ "${ENABLE_FIREWALL:-true}" = "true" ] && [ "${node_env}" = "production" ]; then
        log_info "Firewall wird konfiguriert..."
        if [ -f "scripts/security/setup-firewall.sh" ]; then
            bash scripts/security/setup-firewall.sh --ssh-port "${SSH_PORT:-2222}" --non-interactive 2>/dev/null || {
                log_warning "Firewall-Setup fehlgeschlagen (nicht kritisch)"
            }
        else
            log_warning "Firewall-Script nicht gefunden: scripts/security/setup-firewall.sh"
        fi
    elif [ "${ENABLE_FIREWALL:-true}" != "true" ]; then
        log_info "Firewall-Setup uebersprungen (ENABLE_FIREWALL=false)"
    else
        log_info "Firewall-Setup uebersprungen (NODE_ENV != production)"
    fi
}

# Install systemd watchdog and deadman-switch timers
install_systemd_timers() {
    if [ "${INSTALL_SYSTEMD_TIMERS:-true}" != "true" ]; then
        log_info "Systemd-Timer-Installation uebersprungen (INSTALL_SYSTEMD_TIMERS=false)"
        return 0
    fi

    log_info "Installiere Systemd-Timer (Watchdog, Deadman-Switch)..."

    local installed=0

    # Copy timer files
    for timer_file in packaging/arasul-platform/etc/systemd/system/*.timer; do
        if [ -f "$timer_file" ]; then
            sudo cp "$timer_file" /etc/systemd/system/ 2>/dev/null || true
            installed=$((installed + 1))
        fi
    done

    # Copy associated service files
    for service_file in packaging/arasul-platform/etc/systemd/system/docker-watchdog.service \
                        packaging/arasul-platform/etc/systemd/system/deadman-switch.service; do
        if [ -f "$service_file" ]; then
            sudo cp "$service_file" /etc/systemd/system/ 2>/dev/null || true
            installed=$((installed + 1))
        fi
    done

    if [ $installed -gt 0 ]; then
        sudo systemctl daemon-reload 2>/dev/null || true
        sudo systemctl enable --now docker-watchdog.timer deadman-switch.timer 2>/dev/null || {
            log_warning "Systemd-Timer konnten nicht aktiviert werden"
            return 0
        }
        log_success "Systemd-Timer installiert und aktiviert ($installed Dateien)"
    else
        log_warning "Keine Systemd-Timer-Dateien gefunden"
    fi
}

# Bootstrap command
cmd_bootstrap() {
    show_banner
    check_root

    # 1. Hardware validieren
    if ! validate_hardware; then
        log_error "Hardware-Validierung fehlgeschlagen."
        log_info "Mindestanforderungen:"
        log_info "  - NVIDIA GPU mit installierten Treibern"
        log_info "  - Mindestens 16GB RAM (32GB+ empfohlen)"
        log_info "  - Mindestens 64GB Speicherplatz (128GB+ empfohlen)"
        exit 1
    fi

    # 2. Software-Voraussetzungen
    check_requirements

    # 3. Interactive Setup (generiert .env)
    if [ ! -f .env ] || [ "$FORCE_SETUP" = "true" ]; then
        run_interactive_setup
    else
        log_info ".env existiert bereits, ueberspringe Setup"
        log_info "Tipp: ./arasul setup  um die Konfiguration zu aendern"
    fi

    # 4. Jetson-Profil anwenden
    apply_jetson_profile

    # 5. Konfiguration validieren
    log_info "Validiere Konfiguration..."
    if [ -f "${SCRIPT_DIR}/scripts/validate/validate_config.sh" ]; then
        if ! "${SCRIPT_DIR}/scripts/validate/validate_config.sh"; then
            log_error "Konfigurationsvalidierung fehlgeschlagen"
            exit 1
        fi
    fi

    if [ -f "${SCRIPT_DIR}/scripts/validate/validate_dependencies.sh" ]; then
        if ! "${SCRIPT_DIR}/scripts/validate/validate_dependencies.sh"; then
            log_error "Abhaengigkeitsvalidierung fehlgeschlagen"
            exit 1
        fi
    fi

    # 6. Verzeichnisse erstellen
    create_directories

    # 7. Secrets & Auth konfigurieren
    setup_secrets

    # 8. TLS-Zertifikate
    setup_https

    # 8b. Basic-Auth-Hash Validierung
    validate_basic_auth_hash

    # 9. Docker-Images (--skip-pull / --skip-build fuer Factory-Images)
    if [ "$SKIP_PULL" != "true" ]; then
        pull_images
    else
        log_info "Image-Pull uebersprungen (--skip-pull)"
    fi

    if [ "$SKIP_BUILD" != "true" ]; then
        build_images
    else
        log_info "Image-Build uebersprungen (--skip-build)"
    fi

    # 10. Datenbank initialisieren
    init_database

    # 11. Services starten
    start_services

    # 12. Warten auf Stabilisierung (MinIO muss bereit sein fuer Bucket-Init)
    log_info "Warte auf Service-Stabilisierung..."
    wait_for_healthy minio 30 "docker compose exec -T minio curl -sf http://localhost:9000/minio/health/live" || true

    # 13. MinIO-Buckets erstellen
    init_minio_buckets

    # 14. Admin-Benutzer anlegen
    init_admin_user

    # 15. Smoke Tests & Ergebnis
    if run_smoke_tests; then

        # 16. Production-Haertung (nicht kritisch - Fehler blockieren Bootstrap nicht)
        harden_production_security

        # 17. Systemd-Timer installieren
        install_systemd_timers

        generate_error_report 0 "completed"
        show_completion_summary

        # 18. Klartext-Passwort aus .env entfernen (Sicherheit)
        redact_plaintext_password
    else
        generate_error_report 1 "smoke_tests"
        exit 1
    fi
}

