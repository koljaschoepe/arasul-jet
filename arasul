# Main command dispatcher
case "${1:-help}" in
    setup)
        cmd_setup
        ;;
    bootstrap)
        # Parse bootstrap flags
        shift
        for arg in "$@"; do
            case "$arg" in
                --skip-pull)   SKIP_PULL=true ;;
                --skip-build)  SKIP_BUILD=true ;;
                --force-setup) FORCE_SETUP=true ;;
            esac
        done
        cmd_bootstrap
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    logs)
        cmd_logs "$@"
        ;;
    update)
        cmd_update
        ;;
    mdns)
        cmd_mdns
        ;;
    validate-config)
        shift
        cmd_validate_config "$@"
        ;;
    validate-deps)
        shift
        cmd_validate_dependencies "$@"
        ;;
    setup-secrets)
        cmd_setup_secrets
        ;;
    reload-config)
        cmd_reload_config
        ;;
    test-load)
        shift
        cmd_test_load "$@"
        ;;
    test-restart)
        cmd_test_restart
        ;;
    test-stability)
        shift
        cmd_test_stability "$@"
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        log_error "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
