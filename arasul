        bash "${SCRIPT_DIR}/scripts/interactive_setup.sh"
        if [ $? -ne 0 ]; then
            log_error "Setup abgebrochen"
            exit 1
        fi
    else
        log_error "Setup-Script nicht gefunden: scripts/interactive_setup.sh"
        exit 1
    fi
}

# Apply Jetson hardware profile (only if not already embedded by interactive_setup)
apply_jetson_profile() {
    local detect_script="${SCRIPT_DIR}/scripts/setup/detect-jetson.sh"
    if [ -f "$detect_script" ]; then
        # Skip if interactive_setup already embedded the profile in .env
        if grep -q "^JETSON_PROFILE=" .env 2>/dev/null; then
            local existing_profile=$(grep "^JETSON_PROFILE=" .env | cut -d'=' -f2)
            log_info "Jetson-Profil bereits in .env vorhanden: ${existing_profile} (ueberspringe)"
            return 0
        fi

        log_info "Wende Jetson-Profil an..."
        bash "$detect_script" generate >/dev/null 2>&1 || true
        bash "$detect_script" apply >/dev/null 2>&1 || true
        log_success "Jetson-Profil angewendet"
    fi
}

