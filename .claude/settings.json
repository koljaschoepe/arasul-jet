{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Team-shared Claude Code settings. Personal overrides (Telegram-notify, auto-typecheck, ...) go in settings.local.json (gitignored). See .claude/settings.local.example.json for a starting point.",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker exec:*)",
      "Bash(docker inspect:*)",
      "Bash(docker info:*)",
      "Bash(docker cp:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(jest:*)",
      "Bash(make:*)",
      "Bash(curl localhost:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl 127.0.0.1:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod +x:*)",
      "Bash(./scripts/*:*)",
      "Bash(./scripts/test/run-tests.sh:*)",
      "Bash(./scripts/validate/validate_dependencies.sh:*)",
      "Bash(./scripts/validate/validate_config.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-destructive.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
