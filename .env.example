# =============================================================================
# Arasul Platform - Environment Variables Template
# Generated by: ./arasul setup (interactive_setup.sh)
# Documentation: docs/ENVIRONMENT_VARIABLES.md
# =============================================================================

# --- System ---
SYSTEM_NAME=arasul
SYSTEM_VERSION=1.0.0
NODE_ENV=production

# --- Administrator (set during setup) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<generated-during-setup>
ADMIN_EMAIL=admin@example.com

# --- Security (auto-generated, DO NOT use weak values) ---
# JWT_SECRET: min 32 chars, generated with: openssl rand -hex 32
JWT_SECRET=<generated-during-setup>
# N8N/Telegram keys: generated with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=<generated-during-setup>
TELEGRAM_ENCRYPTION_KEY=<generated-during-setup>

# --- Database ---
POSTGRES_USER=arasul
POSTGRES_PASSWORD=<generated-during-setup>
POSTGRES_DB=arasul_db
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432

# --- MinIO (S3 Storage) ---
MINIO_ROOT_USER=arasul
MINIO_ROOT_PASSWORD=<generated-during-setup>
MINIO_HOST=minio
MINIO_PORT=9000

# --- AI Model ---
LLM_MODEL=qwen3:14b
LLM_SERVICE_HOST=llm-service
LLM_SERVICE_PORT=11434

# --- Embedding ---
EMBEDDING_SERVICE_HOST=embedding-service
EMBEDDING_SERVICE_PORT=11435
EMBEDDING_MODEL=BAAI/bge-m3

# --- Qdrant (Vector DB) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Dashboard ---
DASHBOARD_BACKEND_PORT=3001
JWT_EXPIRY=24h
LOG_LEVEL=info
